# ───── Источник данных ─────
# 'local'  — SQLite + data.json (по умолчанию)
# 'bitrix' — Битрикс24 через входящий вебхук
DATA_PROVIDER=local

# ───── Настройки Битрикс24 (нужны только при DATA_PROVIDER=bitrix) ─────
# URL входящего вебхука вида https://albatros.bitrix24.ru/rest/1/<токен>/
# Создаётся в Битриксе: Разработчикам → Другое → Входящий вебхук.
BITRIX_WEBHOOK_URL=

# Идентификаторы универсальных списков (число) — посмотрите URL списка
# в Битриксе после его создания, например /lists/12/ → 12.
BITRIX_LIST_TRAINERS=
BITRIX_LIST_SCHEDULE=
